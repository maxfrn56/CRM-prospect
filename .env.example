# PostgreSQL — local via Docker (docker compose up -d)
# DATABASE_URL="postgresql://prospect:prospect@localhost:5432/prospect_crm?schema=public"
# Railway injecte automatiquement DATABASE_URL depuis le service PostgreSQL
DATABASE_URL="postgresql://prospect:prospect@localhost:5432/prospect_crm?schema=public"

# Google Places — Recherche entreprises par secteur + ville
GOOGLE_PLACES_API_KEY=""

# Google Gemini — Génération d'emails et analyse des réponses
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

# Resend — Envoi et réception d'emails
# https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="prospection@votredomaine.com"
# Adresse où arrivent les RÉPONSES prospects — DOIT être gérée par Resend (Inbound)
# Pas votre boîte Zimbra/Gmail perso. Exemples :
#   prospection@replies.votredomaine.com  (sous-domaine avec MX Resend)
#   xxxxx@inbound.resend.app              (adresse fournie par Resend → Receiving)
RESEND_INBOUND_EMAIL=""
RESEND_REPLY_TO="prospection@votredomaine.com"
RESEND_WEBHOOK_SECRET=""

# URL optionnelle du CSV annuaire avocats CNB (data.gouv.fr)
# CNB_AVOCATS_CSV_URL="https://static.data.gouv.fr/resources/annuaire-des-avocats-de-france/.../annuaire-avocats-20260420.csv"

# Pappers — Optionnel, enrichissement email/téléphone
# https://www.pappers.fr/api
PAPPERS_API_KEY=""

# Sécurité cron (relances automatiques)
CRON_SECRET="changez-moi-en-production"

# URL publique de l'app (pour webhooks Resend)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cursor Cloud Agents — création automatique de maquettes
# https://cursor.com/settings (API Keys)
CURSOR_API_KEY=""
# Optionnel — modèle explicite (sinon défaut du compte Cursor)
# CURSOR_AGENT_MODEL="composer-2.5"
